{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@assetport/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src", "manifest.ts", "vite.config.ts"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}
